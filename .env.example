# =============================================================================
# mcp-guard 配置文件
# 复制此文件为 .env 并修改配置
# =============================================================================

# MCP 传输模式 (stdio / sse / http)
# 留空则自动检测：TTY → http，非 TTY → stdio
MCP_TRANSPORT=

# 每日预算上限（USDC）
BUDGET_LIMIT=10.0

# 高风险金额阈值（超过此金额自动触发审批）
HIGH_RISK_THRESHOLD=2.0

# 高风险资源关键词（逗号分隔，匹配到则触发审批）
HIGH_RISK_RESOURCES=delete,send

# SQLite 数据库路径
DB_PATH=./mcp-guard.db

# Dashboard HTTP 端口
DASHBOARD_PORT=8080

# 审批链接基础 URL（用于 Telegram 通知中的链接）
APPROVAL_BASE_URL=http://localhost:8080

# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info

# 付款方标识（留空则使用主机名）
PAYER_ID=

# Telegram 通知（可选，不配置则跳过）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
